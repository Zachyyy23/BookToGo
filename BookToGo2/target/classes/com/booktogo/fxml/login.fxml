<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.booktogo.controller.LoginController"
            styleClass="login-page">

    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="login-card">
            <Label text="BookToGo" styleClass="app-title"/>
            <Label text="Library Management System" styleClass="subtitle"/>

            <TextField fx:id="emailField" promptText="Email" styleClass="input-field"/>
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>

            <Button text="Login" onAction="#handleLogin" styleClass="primary-button"/>

            <Label text="Demo: click Login to open the Student Dashboard"
                   styleClass="helper-text"/>
        </VBox>
    </center>

</BorderPane>